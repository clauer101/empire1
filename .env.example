# Copy this file to .env and fill in real values before starting the server.
# Generate JWT_SECRET: python -c "import secrets; print(secrets.token_hex(32))"

JWT_SECRET=replace-with-32-byte-random-hex

# Site identity — used in index.html SEO meta tags and structured data
SITE_URL=https://relicsnrockets.io
SITE_NAME="Relics & Rockets"

# TLS certificate paths (set to your Let's Encrypt or self-signed cert locations)
# Never commit the actual files — store them outside the repo, e.g. /etc/letsencrypt/live/
TLS_CERT_PATH=/etc/letsencrypt/live/yourdomain/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/yourdomain/privkey.pem

# VAPID keys for Web Push notifications
# Generate: python3 -m py_vapid --gen
VAPID_PRIVATE_KEY_PATH=/etc/empire1/vapid/vapid_private.pem
VAPID_PUBLIC_KEY_PATH=/etc/empire1/vapid/vapid_public.pem
