{
  "name": "relics-and-rockets",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/optimize-assets.mjs --write && vite build",
    "preview": "vite preview",
    "assets:optimize": "node scripts/optimize-assets.mjs --write",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint js/",
    "lint:fix": "eslint js/ --fix",
    "format": "prettier --write js/ css/",
    "format:check": "prettier --check js/ css/"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "vite": "^6.3.5"
  }
}
